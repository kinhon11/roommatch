@startuml
title Sequence Diagram: Create Room Deposit Process

actor "Người thuê" as Tenant
boundary "Deposits UI" as UI
control "Deposit Controller" as DepositCtrl
database "Rooms Table" as Rooms
database "Roommate Requests / Appointments" as Eligibility
database "Room Deposits Table" as Deposits
database "Notifications Table" as Notifications

Tenant -> UI: Chọn phòng và nhập số tiền cọc
Tenant -> UI: Nhấn "Gửi yêu cầu đặt cọc"
UI -> DepositCtrl: POST /api/deposits
DepositCtrl -> Rooms: Lấy thông tin phòng

alt Phòng không tồn tại
  Rooms --> DepositCtrl: Không có dữ liệu
  DepositCtrl --> UI: 404 Not Found
  UI --> Tenant: Phòng không tồn tại
else Số tiền không hợp lệ
  DepositCtrl --> UI: 400 Bad Request
  UI --> Tenant: Số tiền cọc không hợp lệ
else Phòng hợp lệ
  Rooms --> DepositCtrl: room + landlord_id
  DepositCtrl -> Eligibility: Kiểm tra yêu cầu ở ghép đã duyệt hoặc lịch hẹn đã hoàn thành
  alt Chưa đủ điều kiện đặt cọc
    Eligibility --> DepositCtrl: Không có điều kiện phù hợp
    DepositCtrl --> UI: 403 Forbidden
    UI --> Tenant: Chưa đủ điều kiện đặt cọc
  else Đủ điều kiện đặt cọc
    Eligibility --> DepositCtrl: roommate_request_id hoặc appointment_id
    DepositCtrl -> Deposits: Kiểm tra cọc đang hoạt động
    alt Phòng đã có cọc đang giữ
      Deposits --> DepositCtrl: Active deposit exists
      DepositCtrl --> UI: 409 Conflict
      UI --> Tenant: Phòng đã có yêu cầu đặt cọc
    else Có thể tạo cọc
      DepositCtrl -> Deposits: Insert deposit status = pending_payment
      Deposits --> DepositCtrl: Deposit mới
      DepositCtrl -> Notifications: Thông báo cho chủ trọ
      Notifications --> DepositCtrl: Notification created
      DepositCtrl --> UI: 201 Created
      UI --> Tenant: Gửi yêu cầu đặt cọc thành công
    end
  end
end

@enduml
