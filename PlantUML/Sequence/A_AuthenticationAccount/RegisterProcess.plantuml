@startuml
title Sequence Diagram: Register Process

actor "Người dùng" as User
boundary "Register UI" as UI
control "Auth Controller" as Auth
database "Supabase Auth" as SupaAuth
database "Users Table" as Users

User -> UI: Nhập email, mật khẩu, họ tên, vai trò
User -> UI: Nhấn "Đăng ký"
UI -> Auth: POST /api/auth/register
Auth -> Auth: Validate dữ liệu và vai trò

alt Dữ liệu không hợp lệ
  Auth --> UI: 400 Bad Request
  UI --> User: Hiển thị lỗi đăng ký
else Dữ liệu hợp lệ
  Auth -> SupaAuth: signUp(email, password, metadata)
  alt Supabase Auth lỗi
    SupaAuth --> Auth: Auth error
    Auth --> UI: 400 Bad Request
    UI --> User: Hiển thị lỗi từ hệ thống xác thực
  else Tạo Auth user thành công
    SupaAuth --> Auth: Auth user + session
    Auth -> Users: Insert public.users
    alt Lưu hồ sơ thất bại
      Users --> Auth: Insert error
      Auth -> SupaAuth: Rollback deleteUser(userId)
      Auth --> UI: 500 Server Error
      UI --> User: Không thể lưu thông tin người dùng
    else Lưu hồ sơ thành công
      Users --> Auth: User profile
      opt Chưa có session sau đăng ký
        Auth -> SupaAuth: signInWithPassword(email, password)
        SupaAuth --> Auth: Session
      end
      Auth --> UI: User + Session
      UI -> UI: Lưu session
      UI --> User: Đăng ký thành công
    end
  end
end

@enduml
