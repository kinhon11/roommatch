@startuml
title Entity Relationship Diagram (ERD)\nHệ thống RoommieMatch

hide circle
skinparam linetype ortho
skinparam ranksep 55
skinparam nodesep 42
skinparam shadowing false
skinparam defaultFontName "DejaVu Sans"
skinparam ArrowColor #64748B
skinparam entity {
  BorderColor #334155
  FontSize 12
}

' ========== CORE DATA (Xanh lá) ==========
entity "**users**" as users #E8F5E9 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  email : TEXT <<UNIQUE>>
  full_name : TEXT
  role : TEXT
  phone : TEXT
  is_verified : BOOLEAN
  is_locked : BOOLEAN
}

entity "**rooms**" as rooms #E8F5E9 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>host_id</color> : UUID <<FK>>
  <color:#666>broker_id</color> : UUID <<FK>>
  title : TEXT
  price : NUMERIC
  address : TEXT
  status : TEXT
  is_available : BOOLEAN
}

entity "**room_images**" as room_images #E8F5E9 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>room_id</color> : UUID <<FK>>
  image_url : TEXT
  is_primary : BOOLEAN
}

entity "**amenities**" as amenities #E8F5E9 {
  <color:#b8860b><b>id</b></color> : INT <<PK>>
  --
  name : TEXT
  icon : TEXT
}

entity "**room_amenities**" as room_amenities #E8F5E9 {
  <color:#666>room_id</color> : UUID <<PK, FK>>
  <color:#666>amenity_id</color> : INT <<PK, FK>>
}

' ========== TENANT FLOW (Cam) ==========
entity "**roommate_requests**" as roommate_requests #FFF3E0 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>room_id</color> : UUID <<FK>>
  <color:#666>tenant_id</color> : UUID <<FK>>
  status : TEXT
  move_in_date : DATE
}

entity "**appointments**" as appointments #FFF3E0 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>room_id</color> : UUID <<FK>>
  <color:#666>tenant_id</color> : UUID <<FK>>
  <color:#666>landlord_id</color> : UUID <<FK>>
  scheduled_at : TIMESTAMPTZ
  status : TEXT
}

entity "**room_deposits**" as room_deposits #FFF3E0 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>room_id</color> : UUID <<FK>>
  <color:#666>tenant_id</color> : UUID <<FK>>
  <color:#666>landlord_id</color> : UUID <<FK>>
  amount : NUMERIC
  status : TEXT
}

' ========== BROKER FLOW (Xanh dương) ==========
entity "**broker_leads**" as broker_leads #E3F2FD {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>broker_id</color> : UUID <<FK>>
  <color:#666>tenant_id</color> : UUID <<FK>>
  <color:#666>assigned_room_id</color> : UUID <<FK>>
  full_name : TEXT
  phone : TEXT
  status : TEXT
}

entity "**broker_lead_rooms**" as broker_lead_rooms #E3F2FD {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>lead_id</color> : UUID <<FK>>
  <color:#666>room_id</color> : UUID <<FK>>
  match_reason : TEXT
  status : TEXT
}

entity "**broker_commissions**" as broker_commissions #E3F2FD {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>broker_id</color> : UUID <<FK>>
  <color:#666>lead_id</color> : UUID <<FK>>
  <color:#666>room_id</color> : UUID <<FK>>
  amount : NUMERIC
  status : TEXT
}

' ========== COMMUNICATION & FEEDBACK (Tím) ==========
entity "**conversations**" as conversations #F3E5F5 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>room_id</color> : UUID <<FK>>
  <color:#666>tenant_id</color> : UUID <<FK>>
  <color:#666>landlord_id</color> : UUID <<FK>>
  last_message : TEXT
}

entity "**messages**" as messages #F3E5F5 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>conversation_id</color> : UUID <<FK>>
  <color:#666>sender_id</color> : UUID <<FK>>
  content : TEXT
  is_read : BOOLEAN
}

entity "**notifications**" as notifications #F3E5F5 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>user_id</color> : UUID <<FK>>
  type : TEXT
  read : BOOLEAN
}

entity "**favorites**" as favorites #F3E5F5 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>user_id</color> : UUID <<FK>>
  <color:#666>room_id</color> : UUID <<FK>>
}

entity "**reviews**" as reviews #F3E5F5 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>room_id</color> : UUID <<FK>>
  <color:#666>user_id</color> : UUID <<FK>>
  rating : SMALLINT
  comment : TEXT
}

entity "**reports**" as reports #F3E5F5 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>reporter_id</color> : UUID <<FK>>
  <color:#666>room_id</color> : UUID <<FK>>
  reason : TEXT
  status : TEXT
}

' ========== ADMIN & AUDIT (Xám) ==========
entity "**room_approval_history**" as approval_history #ECEFF1 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>room_id</color> : UUID <<FK>>
  <color:#666>admin_id</color> : UUID <<FK>>
  status : TEXT
  reason : TEXT
}

entity "**room_activity_logs**" as activity_logs #ECEFF1 {
  <color:#b8860b><b>id</b></color> : UUID <<PK>>
  --
  <color:#666>room_id</color> : UUID <<FK>>
  <color:#666>actor_id</color> : UUID <<FK>>
  action : TEXT
}

' ========== LAYOUT CONTROL ==========
' Bố cục dạng ô lưới giống mẫu báo cáo: lõi ở giữa, các phân hệ bao quanh.

' Hàng trên: tài khoản và quản trị
notifications -[hidden]right- users
users -[hidden]right- approval_history
approval_history -[hidden]right- activity_logs

' Hàng giữa: giao tiếp, phòng, môi giới
conversations -[hidden]right- messages
messages -[hidden]right- rooms
rooms -[hidden]right- broker_leads

' Hàng nghiệp vụ chính
roommate_requests -[hidden]right- appointments
appointments -[hidden]right- room_deposits
room_deposits -[hidden]right- broker_lead_rooms
broker_lead_rooms -[hidden]right- broker_commissions

' Hàng dữ liệu phụ của phòng và phản hồi
favorites -[hidden]right- reviews
reviews -[hidden]right- reports
reports -[hidden]right- room_images
room_images -[hidden]right- room_amenities
room_amenities -[hidden]right- amenities

' Liên kết dọc để giữ hình gần vuông, không kéo dài ngang/dọc.
users -[hidden]down- rooms
rooms -[hidden]down- appointments
appointments -[hidden]down- reviews
broker_leads -[hidden]down- broker_lead_rooms
conversations -[hidden]down- roommate_requests
messages -[hidden]down- appointments
approval_history -[hidden]down- broker_leads
activity_logs -[hidden]down- broker_commissions

' ========== RELATIONSHIPS ==========
' Core
users ||--o{ rooms : "đăng / phụ trách"
rooms ||--o{ room_images : "có ảnh"
rooms ||--o{ room_amenities : "có"
amenities ||--o{ room_amenities : "tiện ích"

' Tenant flow
users ||--o{ roommate_requests : "gửi"
rooms ||--o{ roommate_requests : "nhận yêu cầu"
rooms ||--o{ appointments : "lịch xem"
rooms ||--o{ room_deposits : "cọc phòng"

' Broker flow
users ||--o{ broker_leads : "quản lý lead"
broker_leads ||--o{ broker_lead_rooms : "gợi ý"
rooms ||--o{ broker_lead_rooms : "được gợi ý"
broker_leads ||--o{ broker_commissions : "phát sinh"
rooms ||--o{ broker_commissions : "tính hoa hồng"

' Communication & feedback
rooms ||--o{ conversations : "trao đổi"
conversations ||--o{ messages : "chứa"
users ||--o{ notifications : "nhận"
rooms ||--o{ favorites : "được lưu"
rooms ||--o{ reviews : "đánh giá"
rooms ||--o{ reports : "báo cáo"

' Admin & audit
rooms ||--o{ approval_history : "kiểm duyệt"
rooms ||--o{ activity_logs : "ghi log"

' ========== SYMBOLIC FK LINKS ==========
' Các đường nét đứt chỉ biểu diễn FK phụ, tránh làm bố cục bị kéo lệch quá nhiều.
users .. appointments : "FK"
users .. room_deposits : "FK"
users .. conversations : "FK"
users .. messages : "FK"
users .. favorites : "FK"
users .. reviews : "FK"
users .. reports : "FK"
users .. approval_history : "FK"
users .. activity_logs : "FK"
rooms .. broker_leads : "FK"
users .. broker_commissions : "FK"

' ========== LEGEND ==========
legend bottom
  | <#E8F5E9> Dữ liệu lõi | <#FFF3E0> Người thuê | <#E3F2FD> Môi giới | <#F3E5F5> Giao tiếp & Phản hồi | <#ECEFF1> Quản trị / Audit |
endlegend

@enduml
