@startuml
title ERD chính hệ thống RoommieMatch

hide circle
skinparam linetype ortho
skinparam shadowing false
skinparam entity {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
}

entity "users" as users {
  * id : UUID <<PK>>
  --
  email : TEXT <<UNIQUE>>
  full_name : TEXT
  role : TEXT
  phone : TEXT
  avatar_url : TEXT
  is_locked : BOOLEAN
  is_verified : BOOLEAN
}

entity "rooms" as rooms {
  * id : UUID <<PK>>
  --
  host_id : UUID <<FK>>
  title : TEXT
  description : TEXT
  price : INTEGER
  address : TEXT
  city : TEXT
  area : NUMERIC
  status : TEXT
  is_available : BOOLEAN
  is_hidden : BOOLEAN
  available_slots : INT
  created_at : TIMESTAMPTZ
}

entity "room_images" as room_images {
  * id : UUID <<PK>>
  --
  room_id : UUID <<FK>>
  image_url : TEXT
  is_primary : BOOLEAN
  created_at : TIMESTAMPTZ
}

entity "amenities" as amenities {
  * id : UUID <<PK>>
  --
  name : TEXT <<UNIQUE>>
  icon : TEXT
}

entity "room_amenities" as room_amenities {
  * room_id : UUID <<PK, FK>>
  * amenity_id : UUID <<PK, FK>>
}

entity "favorites" as favorites {
  * id : UUID <<PK>>
  --
  user_id : UUID <<FK>>
  room_id : UUID <<FK>>
  created_at : TIMESTAMPTZ
}

entity "reviews" as reviews {
  * id : UUID <<PK>>
  --
  room_id : UUID <<FK>>
  user_id : UUID <<FK>>
  rating : SMALLINT
  comment : TEXT
  is_hidden : BOOLEAN
  landlord_response : TEXT
  landlord_responded_at : TIMESTAMPTZ
  created_at : TIMESTAMPTZ
}

entity "roommate_requests" as roommate_requests {
  * id : UUID <<PK>>
  --
  room_id : UUID <<FK>>
  tenant_id : UUID <<FK>>
  status : TEXT
  message : TEXT
  move_in_date : DATE
  occupants : INT
  has_pet : BOOLEAN
  rejection_reason : TEXT
  created_at : TIMESTAMPTZ
}

entity "appointments" as appointments {
  * id : UUID <<PK>>
  --
  room_id : UUID <<FK>>
  tenant_id : UUID <<FK>>
  landlord_id : UUID <<FK>>
  scheduled_at : TIMESTAMPTZ
  status : TEXT
  cancellation_reason : TEXT
  created_at : TIMESTAMPTZ
}

entity "conversations" as conversations {
  * id : UUID <<PK>>
  --
  room_id : UUID <<FK>>
  tenant_id : UUID <<FK>>
  landlord_id : UUID <<FK>>
  last_message : TEXT
  last_message_at : TIMESTAMPTZ
  created_at : TIMESTAMPTZ
}

entity "messages" as messages {
  * id : UUID <<PK>>
  --
  conversation_id : UUID <<FK>>
  sender_id : UUID <<FK>>
  content : TEXT
  is_read : BOOLEAN
  created_at : TIMESTAMPTZ
}

entity "notifications" as notifications {
  * id : UUID <<PK>>
  --
  user_id : UUID <<FK>>
  type : TEXT
  payload : JSONB
  read : BOOLEAN
  created_at : TIMESTAMPTZ
}

entity "reports" as reports {
  * id : UUID <<PK>>
  --
  reporter_id : UUID <<FK>>
  room_id : UUID <<FK>>
  reason : TEXT
  description : TEXT
  status : TEXT
  resolved_at : TIMESTAMPTZ
  created_at : TIMESTAMPTZ
}

users ||--o{ rooms : "host_id"
rooms ||--o{ room_images : "room_id"
rooms ||--o{ room_amenities : "room_id"
amenities ||--o{ room_amenities : "amenity_id"

users ||--o{ favorites : "user_id"
rooms ||--o{ favorites : "room_id"

users ||--o{ reviews : "user_id"
rooms ||--o{ reviews : "room_id"

users ||--o{ roommate_requests : "tenant_id"
rooms ||--o{ roommate_requests : "room_id"

users ||--o{ appointments : "tenant_id"
users ||--o{ appointments : "landlord_id"
rooms ||--o{ appointments : "room_id"

users ||--o{ conversations : "tenant_id"
users ||--o{ conversations : "landlord_id"
rooms ||--o{ conversations : "room_id"
conversations ||--o{ messages : "conversation_id"
users ||--o{ messages : "sender_id"

users ||--o{ notifications : "user_id"

users ||--o{ reports : "reporter_id"
rooms ||--o{ reports : "room_id"

@enduml
