@startuml
title Activity Diagram: 2.3.8. Quy trình Chatbot

skinparam shadowing false
skinparam defaultFontName "DejaVu Sans"
skinparam activity {
  BackgroundColor #EAF7EA
  BorderColor #8BC58B
  FontColor #111827
  DiamondBackgroundColor #F7FFF7
  DiamondBorderColor #8BC58B
  StartColor #111827
  EndColor #111827
  BarColor #111827
}
skinparam arrow {
  Color #444444
  FontColor #111827
}

start
:Người dùng mở Chatbot / Trợ lý AI;
:Nhập câu hỏi hoặc nhu cầu tìm phòng;
:Nhấn gửi tin nhắn;

:Frontend kiểm tra nội dung câu hỏi;
if (Tin nhắn rỗng?) then (Có)
  :Báo lỗi "Vui lòng nhập nội dung";
  stop
else (Không)
endif

:Gửi request đến API /api/ai/assistant;
:Backend nhận message, conversation và context;

fork
  :Xác định intent\n(search, room_detail, compare, usage, general);
fork again
  :Tải tín hiệu người dùng\n(phòng yêu thích, yêu cầu đã gửi);
fork again
  :Lấy ngữ cảnh phòng hiện tại nếu có;
end fork

:Xây dựng preference profile\nvà tiêu chí tìm kiếm;
:Chạy tool router;

fork
  :Tìm phòng phù hợp theo tiêu chí;
fork again
  :Nếu đang xem phòng,\nso sánh với phòng gợi ý;
fork again
  :Nếu hỏi review,\ntóm tắt đánh giá phòng;
fork again
  :Nếu hỏi cách dùng,\nchuẩn bị hướng dẫn sử dụng app;
end fork

:Tổng hợp tool results, rooms,\ncriteria và follow-up prompts;

if (AI provider được cấu hình?) then (Có)
  :Xây dựng prompt có dữ liệu phòng,\nngữ cảnh và lịch sử hội thoại;
  :Gọi AI provider\n(Gemini/MiniMax theo cấu hình);
  if (AI trả lời thành công?) then (Có)
    :Nhận câu trả lời từ AI;
  else (Không)
    :Ghi log lỗi AI;
    :Tạo fallback reply từ dữ liệu phòng có sẵn;
  endif
else (Không)
  :Tạo fallback reply\nkhông gọi AI bên ngoài;
endif

:Trả response về frontend;

fork
  :Hiển thị câu trả lời chatbot;
fork again
  :Hiển thị danh sách phòng gợi ý nếu có;
fork again
  :Hiển thị câu hỏi gợi ý tiếp theo;
fork again
  :Hiển thị usage tip theo role người dùng;
end fork

if (Người dùng chọn phòng gợi ý?) then (Có)
  :Mở trang chi tiết phòng;
  stop
elseif (Người dùng hỏi tiếp)
  :Thêm tin nhắn vào conversation;
  :Lặp lại quy trình xử lý chatbot;
  stop
else (Kết thúc)
  stop
endif

@enduml
