@startuml
title Activity Diagram: Quy trình chủ trọ đăng phòng và Admin duyệt

skinparam shadowing false
skinparam defaultFontName "DejaVu Sans"
skinparam activity {
  BackgroundColor #EAF7EA
  BorderColor #8BC58B
  FontColor #111827
  DiamondBackgroundColor #F7FFF7
  DiamondBorderColor #8BC58B
  StartColor #111827
  EndColor #111827
  BarColor #111827
}
skinparam arrow {
  Color #444444
  FontColor #111827
}

start
fork
  :Nhập thông tin cơ bản\n(tiêu đề, giá thuê, diện tích, địa chỉ);
fork again
  :Nhập chi phí phòng\n(cọc, điện, nước, wifi, gửi xe, dịch vụ);
fork again
  :Nhập nội quy\n(chung chủ, giờ giấc, pet, nấu ăn, số người);
fork again
  :Tải ảnh phòng và chọn ảnh chính;
end fork

:Nhấn "Đăng tin";
:Backend validate dữ liệu;

if (Dữ liệu hợp lệ?) then (Không)
  :Báo lỗi để chủ trọ sửa lại;
  stop
else (Có)
endif

:Nếu không nhập tiền cọc,\nmặc định cọc = 1 tháng tiền thuê;
:Lưu phòng với trạng thái pending;
:Lưu tiện ích và ảnh phòng;
:Thông báo bài đăng đang chờ duyệt;

:Admin xem danh sách phòng chờ duyệt;
fork
  :Kiểm tra thông tin, giá, cọc, phí;
fork again
  :Kiểm tra ảnh và nội dung mô tả;
fork again
  :Kiểm tra nội quy và dấu hiệu vi phạm;
end fork

if (Bài đăng đạt yêu cầu?) then (Có)
  :Cập nhật trạng thái approved;
  if (Cần nhân viên môi giới phụ trách?) then (Có)
    :Admin gán broker cho phòng;
    :Phòng xuất hiện trong dashboard broker;
  else (Không)
  endif
  :Phòng hiển thị công khai cho tenant;
else (Không)
  :Cập nhật trạng thái rejected;
  :Lưu lý do từ chối;
  :Chủ trọ sửa và gửi duyệt lại nếu cần;
endif

:Thông báo kết quả cho chủ trọ;
stop

@enduml

