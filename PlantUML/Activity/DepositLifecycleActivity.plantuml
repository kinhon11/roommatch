@startuml
title Activity Diagram: Quy trình cọc giữ phòng và hoàn/mất cọc

skinparam shadowing false
skinparam defaultFontName "DejaVu Sans"
skinparam activity {
  BackgroundColor #EAF7EA
  BorderColor #8BC58B
  FontColor #111827
  DiamondBackgroundColor #F7FFF7
  DiamondBorderColor #8BC58B
  StartColor #111827
  EndColor #111827
  BarColor #111827
}
skinparam arrow {
  Color #444444
  FontColor #111827
}

start
:Tenant xem phòng và muốn giữ phòng/giữ slot;
:Nhấn "Gửi yêu cầu cọc";

:Hệ thống kiểm tra điều kiện\n(request được chấp nhận hoặc lịch hẹn hợp lệ);
if (Đủ điều kiện đặt cọc?) then (Không)
  :Báo lỗi chưa đủ điều kiện đặt cọc;
  stop
else (Có)
endif

:Tạo yêu cầu cọc trạng thái pending_payment;
:Tenant thanh toán/chuyển cọc theo hướng dẫn;
:Landlord/Admin xác nhận đã nhận cọc;
:Trạng thái nghiệp vụ = cọc giữ phòng;
:Phòng/slot được giữ, không cho người khác đặt cọc trùng;

if (Tenant vào ở đúng hẹn?) then (Có)
  :Chuyển cọc giữ phòng thành cọc bảo đảm thuê phòng;
  :Tenant nhận phòng / bắt đầu ở;

  if (Tenant trả phòng đúng thỏa thuận?) then (Có)
    :Kiểm tra công nợ, hư hỏng, vi phạm nội quy;
    if (Không nợ/không hư hỏng?) then (Có)
      :Hoàn cọc đầy đủ cho tenant;
      :Đóng hồ sơ cọc;
      stop
    else (Không)
      :Khấu trừ một phần/toàn bộ cọc;
      :Lưu lý do khấu trừ;
      :Hoàn phần còn lại nếu có;
      :Đóng hồ sơ cọc;
      stop
    endif
  else (Không)
    :Tenant bỏ phòng/vi phạm/thông báo sai hạn;
    :Mất cọc hoặc bị khấu trừ theo thỏa thuận;
    :Đóng hồ sơ cọc;
    stop
  endif

else (Không)
  if (Lỗi từ tenant?) then (Có)
    :Tenant đổi ý/không đến ký/không nhận phòng;
    :Tenant mất cọc giữ phòng;
    :Mở lại phòng/slot cho người khác;
    :Đóng hồ sơ cọc;
    stop
  else (Lỗi từ landlord)
    :Landlord không giao phòng/hủy sai cam kết;
    :Hoàn cọc cho tenant;
    :Mở lại hoặc xử lý phòng theo admin;
    :Đóng hồ sơ cọc;
    stop
  endif
endif

@enduml

