@startuml
title Use Case AI hỗ trợ tạo mô tả tin đăng phòng

left to right direction
skinparam shadowing false
actor "Chủ trọ" as Landlord
actor "Gemini API" as Gemini

rectangle "RoommieMatch" {
  (Mở form đăng tin phòng) as OpenRoomForm
  (Nhập thông tin phòng cơ bản) as EnterRoomInfo
  (Yêu cầu AI tạo mô tả) as RequestDescription
  (Kiểm tra giới hạn sử dụng AI) as CheckLimit
  (Tạo mô tả tin đăng bằng AI) as GenerateDescription
  (Xem nội dung AI gợi ý) as ViewSuggestion
  (Chỉnh sửa mô tả) as EditDescription
  (Lưu / gửi duyệt tin đăng) as SaveRoom
}

Landlord --> OpenRoomForm
Landlord --> EnterRoomInfo
Landlord --> RequestDescription
Landlord --> EditDescription
Landlord --> SaveRoom

OpenRoomForm .> EnterRoomInfo : <<include>>
RequestDescription .> CheckLimit : <<include>>
CheckLimit .> GenerateDescription : <<include>>
GenerateDescription --> Gemini
Gemini --> ViewSuggestion
ViewSuggestion .> EditDescription : <<extend>>
EditDescription .> SaveRoom : <<include>>

@enduml
