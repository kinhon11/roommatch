@startuml
title Biểu đồ Use Case tổng quát hệ thống RoommieMatch

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam nodesep 45
skinparam ranksep 55
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
}
skinparam actor {
  BackgroundColor #E0F2FE
  BorderColor #334155
}

actor "Người thuê" as Tenant
actor "Chủ trọ" as Landlord
actor "Admin" as Admin

Tenant -[hidden]down- Admin
Admin -[hidden]down- Landlord

rectangle "RoommieMatch" {
  package "Chức năng chung" {
    usecase "Đăng ký / đăng nhập" as UC_Auth
    usecase "Quản lý hồ sơ" as UC_Profile
    usecase "Trò chuyện" as UC_Chat
    usecase "Trợ lý AI" as UC_AI

    UC_Auth -[hidden]right- UC_Profile
    UC_Profile -[hidden]right- UC_Chat
    UC_Chat -[hidden]right- UC_AI
  }

  package "Người thuê" {
    usecase "Tìm kiếm, xem phòng" as UC_SearchView
    usecase "Yêu thích phòng" as UC_Favorite
    usecase "Đặt lịch xem phòng" as UC_Appointment
    usecase "Yêu cầu ghép / đặt cọc" as UC_RentFlow

    UC_SearchView -[hidden]right- UC_Favorite
    UC_Favorite -[hidden]right- UC_Appointment
    UC_Appointment -[hidden]right- UC_RentFlow
  }

  package "Chủ trọ" {
    usecase "Đăng phòng" as UC_CreateRoom
    usecase "Quản lý phòng" as UC_ManageRoom
    usecase "Quản lý yêu cầu thuê" as UC_ManageRequest
    usecase "Theo dõi lịch hẹn / đặt cọc" as UC_TrackBusiness

    UC_CreateRoom -[hidden]right- UC_ManageRoom
    UC_ManageRoom -[hidden]right- UC_ManageRequest
    UC_ManageRequest -[hidden]right- UC_TrackBusiness
  }

  package "Admin" {
    usecase "Duyệt và quản lý bài đăng" as UC_AdminRooms
    usecase "Quản lý người dùng" as UC_ManageUser
    usecase "Xử lý báo cáo, thống kê" as UC_AdminReportStats

    UC_AdminRooms -[hidden]right- UC_ManageUser
    UC_ManageUser -[hidden]right- UC_AdminReportStats
  }
}

Tenant --> UC_Auth
Tenant --> UC_Profile
Tenant --> UC_Chat
Tenant --> UC_AI
Tenant --> UC_SearchView
Tenant --> UC_Favorite
Tenant --> UC_Appointment
Tenant --> UC_RentFlow

Landlord --> UC_Auth
Landlord --> UC_Profile
Landlord --> UC_Chat
Landlord --> UC_AI
Landlord --> UC_CreateRoom
Landlord --> UC_ManageRoom
Landlord --> UC_ManageRequest
Landlord --> UC_TrackBusiness

Admin --> UC_Auth
Admin --> UC_Profile
Admin --> UC_AdminRooms
Admin --> UC_ManageUser
Admin --> UC_AdminReportStats

UC_SearchView .> UC_AI : <<extend>>
UC_ManageRoom .> UC_AI : <<extend>>
UC_Appointment .> UC_Chat : <<include>>
UC_RentFlow .> UC_Chat : <<include>>

@enduml
