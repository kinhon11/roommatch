@startuml
left to right direction
title General Use Case Diagram - RoommieMatch System

skinparam shadowing false
skinparam defaultFontName "DejaVu Sans"
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FFFDEB
  BorderColor #C2185B
  ArrowColor #C2185B
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #607D8B
}

' Actors
actor "Người thuê\n(Tenant)" as Tenant
actor "Chủ trọ\n(Landlord)" as Landlord
actor "Môi giới\n(Broker)" as Broker
actor "Admin\n(Quản trị viên)" as Admin

rectangle "Hệ thống RoommieMatch (Web App)" {

  ' Shared
  (Đăng nhập / Đăng xuất) as UC_Login
  (Quản lý hồ sơ cá nhân) as UC_Profile
  (Chat & Thông báo) as UC_ChatNotify
  ' Tenant
  package "Phân hệ Người thuê" {
    (Tìm kiếm & Xem phòng) as UC_SearchRoom
    (Yêu thích / Đánh giá / Báo cáo) as UC_TenantInteract
    (Đặt lịch xem phòng) as UC_TenantAppointment
    (Gửi yêu cầu ở ghép / Đặt cọc) as UC_TenantRequestDeposit
  }

  ' Landlord
  package "Phân hệ Chủ trọ" {
    (Đăng & Cập nhật phòng) as UC_PostRoom
    (Quản lý phòng và slot) as UC_ManageRoom
    (Xử lý yêu cầu ở ghép) as UC_HandleRequest
    (Quản lý lịch hẹn & đặt cọc) as UC_LandlordScheduleDeposit
  }

  ' Broker
  package "Phân hệ Môi giới" {
    (Xem phòng được phân công) as UC_AssignedRooms
    (Quản lý lead khách thuê) as UC_ManageLeads
    (Tư vấn & Gợi ý phòng) as UC_RecommendRoom
    (Theo dõi hoa hồng) as UC_BrokerCommission
  }

  ' Admin
  package "Phân hệ Quản trị" {
    (Quản lý người dùng & phân quyền) as UC_ManageUsers
    (Duyệt bài đăng phòng) as UC_ModerateRoom
    (Gán môi giới phụ trách phòng) as UC_AssignBroker
    (Xem báo cáo, thống kê & hoa hồng) as UC_ReportStats
  }
}

' Shared relationships
Tenant -- UC_Login
Landlord -- UC_Login
Broker -- UC_Login
Admin -- UC_Login

Tenant -- UC_Profile
Landlord -- UC_Profile
Broker -- UC_Profile
Admin -- UC_Profile

Tenant -- UC_ChatNotify
Landlord -- UC_ChatNotify
Broker -- UC_ChatNotify

' Tenant logic
Tenant --> UC_SearchRoom
Tenant --> UC_TenantInteract
Tenant --> UC_TenantAppointment
Tenant --> UC_TenantRequestDeposit

' Landlord logic
Landlord --> UC_PostRoom
Landlord --> UC_ManageRoom
Landlord --> UC_HandleRequest
Landlord --> UC_LandlordScheduleDeposit

' Broker logic
Broker --> UC_AssignedRooms
Broker --> UC_ManageLeads
Broker --> UC_RecommendRoom
Broker --> UC_BrokerCommission
Broker --> UC_HandleRequest
Broker --> UC_LandlordScheduleDeposit

' Admin logic
Admin --> UC_ManageUsers
Admin --> UC_ModerateRoom
Admin --> UC_AssignBroker
Admin --> UC_ReportStats

@enduml


