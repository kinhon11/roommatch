@startuml
title Use Case Kiểm duyệt bài đăng phòng

left to right direction
skinparam shadowing false
actor "Admin" as Admin

rectangle "RoommieMatch" {
  (Xem phòng chờ duyệt) as ViewPendingRooms
  (Xem chi tiết bài đăng) as ViewRoomDetail
  (Duyệt bài đăng) as ApproveRoom
  (Từ chối bài đăng) as RejectRoom
  (Gán môi giới phụ trách) as AssignBroker
  (Quản lý toàn bộ phòng) as ManageAllRooms
}

Admin --> ViewPendingRooms
Admin --> ViewRoomDetail
Admin --> ApproveRoom
Admin --> RejectRoom
Admin --> AssignBroker
Admin --> ManageAllRooms

@enduml


