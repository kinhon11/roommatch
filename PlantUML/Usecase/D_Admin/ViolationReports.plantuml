@startuml
title Use Case Xử lý báo cáo vi phạm

left to right direction
skinparam shadowing false
actor "Admin" as Admin
actor "Người dùng" as User

rectangle "RoommieMatch" {
  usecase "Gửi báo cáo vi phạm" as CreateReport
  usecase "Xem danh sách báo cáo" as ViewReports
  usecase "Lọc báo cáo theo trạng thái" as FilterReports
  usecase "Xem chi tiết báo cáo" as ViewReportDetail
  usecase "Xử lý báo cáo" as ResolveReport
  usecase "Bỏ qua báo cáo" as DismissReport
  usecase "Ẩn phòng bị báo cáo nhiều lần" as AutoHideRoom
}

User --> CreateReport
Admin --> ViewReports
Admin --> FilterReports
Admin --> ViewReportDetail
Admin --> ResolveReport
Admin --> DismissReport

CreateReport .> AutoHideRoom : <<extend>>
FilterReports .> ViewReports : <<include>>
ResolveReport .> AutoHideRoom : <<extend>>

@enduml
