@startuml
title Use Case Quản lý Nhân sự & Phân quyền

left to right direction
skinparam shadowing false
actor "Admin" as Admin

rectangle "RoommieMatch" {
  (Xem danh sách người dùng) as ViewUsers
  (Tìm kiếm / lọc người dùng) as FilterUsers
  (Cập nhật vai trò) as UpdateRole
  (Khóa / mở khóa tài khoản) as LockUser
  (Xem thông tin người dùng) as ViewUserDetail
  (Phân quyền môi giới) as AssignBrokerRole
}

Admin --> ViewUsers
Admin --> FilterUsers
Admin --> ViewUserDetail
Admin --> UpdateRole
Admin --> LockUser
Admin --> AssignBrokerRole

FilterUsers .> ViewUsers : <<include>>
ViewUserDetail .> ViewUsers : <<include>>
AssignBrokerRole .> UpdateRole : <<include>>

@enduml


