@startuml
title Use Case Đặt cọc phòng - Người thuê

left to right direction
skinparam shadowing false
skinparam defaultFontName "DejaVu Sans"
skinparam actorStyle awesome

actor "Người thuê" as Tenant

rectangle "RoommieMatch" {
  (Gửi yêu cầu đặt cọc giữ phòng) as CreateDeposit
  (Xem danh sách đặt cọc của tôi) as ViewDeposits
  (Theo dõi trạng thái đặt cọc) as TrackDeposit
  (Hủy yêu cầu cọc khi chưa thanh toán) as CancelDeposit
  (Xem lịch sử trạng thái cọc) as ViewTransactions
  (Nhận thông báo thay đổi cọc) as ReceiveNotification
}

Tenant --> CreateDeposit
Tenant --> ViewDeposits
Tenant --> TrackDeposit
Tenant --> CancelDeposit
Tenant --> ViewTransactions
Tenant --> ReceiveNotification

TrackDeposit .> ViewDeposits : <<include>>
TrackDeposit .> ReceiveNotification : <<include>>
CancelDeposit .> ReceiveNotification : <<include>>
ViewTransactions .> ViewDeposits : <<include>>

@enduml


