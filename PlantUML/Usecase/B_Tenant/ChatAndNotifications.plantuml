@startuml
title Use Case Chat & Thông báo - Người thuê

left to right direction
skinparam shadowing false
actor "Người thuê" as Tenant

rectangle "RoommieMatch" {
  (Mở cuộc trò chuyện) as OpenChat
  (Gửi tin nhắn) as SendMessage
  (Xem tin nhắn) as ViewMessages
  (Xem số tin chưa đọc) as UnreadCount
  (Xem thông báo) as ViewNotifications
  (Đánh dấu thông báo đã đọc) as MarkRead
}

Tenant --> OpenChat
Tenant --> SendMessage
Tenant --> ViewMessages
Tenant --> UnreadCount
Tenant --> ViewNotifications
Tenant --> MarkRead

SendMessage .> ViewNotifications : <<include>>
MarkRead .> ViewNotifications : <<include>>

@enduml


