@startuml
title Use Case Tìm kiếm & Xem phòng

left to right direction
skinparam shadowing false
actor "Người thuê" as Tenant

rectangle "RoommieMatch" {
  (Tìm kiếm phòng) as SearchRooms
  (Lọc phòng theo nhu cầu) as FilterRooms
  (Xem danh sách phòng) as ViewRooms
  (Xem chi tiết phòng) as ViewRoomDetail
  (Xem hồ sơ chủ trọ) as ViewLandlord
  (Lưu phòng yêu thích) as FavoriteRoom
  (Báo cáo phòng vi phạm) as ReportRoom
  (Xem gợi ý phòng tương tự) as SimilarRooms
}

Tenant --> SearchRooms
Tenant --> ViewRooms
Tenant --> ViewRoomDetail
Tenant --> ViewLandlord
Tenant --> FavoriteRoom
Tenant --> ReportRoom

SearchRooms .> FilterRooms : <<include>>
ViewRoomDetail .> SimilarRooms : <<extend>>
ViewRoomDetail .> ViewLandlord : <<include>>

@enduml


