@startuml
title Use Case Tìm kiếm & Xem phòng

left to right direction
skinparam shadowing false
actor "Người thuê" as Tenant

rectangle "RoommieMatch" {
  usecase "Tìm kiếm phòng" as SearchRooms
  usecase "Lọc phòng theo nhu cầu" as FilterRooms
  usecase "Xem danh sách phòng" as ViewRooms
  usecase "Xem chi tiết phòng" as ViewRoomDetail
  usecase "Xem hồ sơ chủ trọ" as ViewLandlord
  usecase "Lưu phòng yêu thích" as FavoriteRoom
  usecase "Báo cáo phòng vi phạm" as ReportRoom
  usecase "Xem gợi ý phòng tương tự" as SimilarRooms
}

Tenant --> SearchRooms
Tenant --> ViewRooms
Tenant --> ViewRoomDetail
Tenant --> ViewLandlord
Tenant --> FavoriteRoom
Tenant --> ReportRoom

SearchRooms .> FilterRooms : <<include>>
ViewRoomDetail .> SimilarRooms : <<extend>>
ViewRoomDetail .> ViewLandlord : <<include>>

@enduml
