@startuml
title Use Case Gửi & Quản lý yêu cầu ở ghép

left to right direction
skinparam shadowing false
actor "Người thuê" as Tenant

rectangle "RoommieMatch" {
  (Kiểm tra trạng thái yêu cầu) as CheckRequest
  (Gửi yêu cầu ở ghép) as CreateRequest
  (Xem danh sách yêu cầu đã gửi) as ListRequests
  (Theo dõi trạng thái duyệt) as TrackStatus
  (Hủy yêu cầu đang chờ) as CancelRequest
  (Nhận thông báo kết quả) as ReceiveNotification
}

Tenant --> CheckRequest
Tenant --> CreateRequest
Tenant --> ListRequests
Tenant --> TrackStatus
Tenant --> CancelRequest
Tenant --> ReceiveNotification

CreateRequest .> CheckRequest : <<include>>
TrackStatus .> ReceiveNotification : <<include>>

@enduml


