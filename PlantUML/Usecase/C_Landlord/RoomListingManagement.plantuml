@startuml
title Use Case Quản lý tin đăng phòng

left to right direction
skinparam shadowing false
actor "Chủ trọ" as Landlord

rectangle "RoommieMatch" {
  (Đăng tin phòng) as CreateRoom
  (Xem danh sách phòng của tôi) as ViewMyRooms
  (Cập nhật tin phòng) as UpdateRoom
  (Ẩn / hiện tin phòng) as ToggleHidden
  (Cập nhật trạng thái còn chỗ) as ToggleAvailable
  (Quản lý hình ảnh phòng) as ManageImages
  (Dùng AI hỗ trợ nội dung tin) as AIListing
}

Landlord --> CreateRoom
Landlord --> ViewMyRooms
Landlord --> UpdateRoom
Landlord --> ToggleHidden
Landlord --> ToggleAvailable
Landlord --> ManageImages
Landlord --> AIListing

CreateRoom .> AIListing : <<extend>>
UpdateRoom .> ManageImages : <<include>>

@enduml


