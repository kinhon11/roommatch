@startuml
title Use Case Đăng nhập, Đăng ký & Quên mật khẩu

left to right direction
skinparam shadowing false
actor "Người thuê" as Tenant
actor "Chủ trọ" as Landlord
actor "Admin" as Admin

rectangle "RoommieMatch" {
  usecase "Đăng ký tài khoản" as Register
  usecase "Đăng nhập" as Login
  usecase "Đăng xuất" as Logout
  usecase "Quên mật khẩu" as ForgotPassword
  usecase "Xác thực thông tin đăng nhập" as ValidateLogin
  usecase "Phân quyền theo vai trò" as AuthorizeRole
}

Tenant --> Register
Landlord --> Register
Tenant --> Login
Landlord --> Login
Admin --> Login
Tenant --> Logout
Landlord --> Logout
Admin --> Logout
Tenant --> ForgotPassword
Landlord --> ForgotPassword
Admin --> ForgotPassword

Login .> ValidateLogin : <<include>>
Login .> AuthorizeRole : <<include>>

@enduml
