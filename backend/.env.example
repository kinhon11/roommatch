# ──────────────────────────────────────────────────
# BACKEND - RoommieMatch API Server
# Sao chép file này thành .env và điền giá trị thật
# ĐỪNG commit file .env lên git
# ──────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Client URL (Frontend - để cấu hình CORS)
CLIENT_URL=http://localhost:5173

# Supabase (Lấy từ: Supabase Dashboard → Project Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Gemini AI (Lấy từ: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSy_your_key_here
GEMINI_MODEL=gemini-2.5-flash
AI_TIMEOUT_MS=25000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=20
